{
  "name": "@sccc/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "npm run db:generate && DATABASE_URL=postgresql://sccc:sccc@localhost:5432/sccc?schema=public prisma validate --schema prisma/schema.prisma",
    "db:generate": "DATABASE_URL=postgresql://sccc:sccc@localhost:5432/sccc?schema=public prisma generate --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:validate": "DATABASE_URL=postgresql://sccc:sccc@localhost:5432/sccc?schema=public prisma validate --schema prisma/schema.prisma",
    "lint": "DATABASE_URL=postgresql://sccc:sccc@localhost:5432/sccc?schema=public prisma validate --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "prisma": "^6.2.1"
  },
  "devDependencies": {
    "@sccc/shared": "0.1.0",
    "tsx": "^4.19.2"
  }
}
