NODE_ENV=production

# Public origins. These are also Docker build args for Next.js public metadata and client URLs.
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_MARKETING_URL=https://example.com

# Local Postgres container credentials used by docker-compose.production.example.yml.
POSTGRES_USER=sccc
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=sccc
DATABASE_URL=postgresql://sccc:replace-with-a-long-random-postgres-password@postgres:5432/sccc?schema=public
SCCC_RESTORE_TEST_DATABASE_URL=

# Redis powers queues and multi-instance rate limits.
REDIS_URL=redis://redis:6379
SCCC_RATE_LIMIT_STORE=

# SaaS secrets.
AUTH_SECRET=replace-with-a-long-random-auth-secret
SCCC_PLUGIN_SIGNING_SECRET=replace-with-plugin-signing-secret
SCCC_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
SCCC_DATA_STORE=prisma

# Email delivery.
SCCC_EMAIL_TRANSPORT=smtp
SCCC_EMAIL_FROM="SEO Content Control Center <no-reply@example.com>"
SCCC_SMTP_HOST=smtp.example.com
SCCC_SMTP_PORT=587
SCCC_SMTP_SECURE=false
SCCC_SMTP_USER=
SCCC_SMTP_PASSWORD=

# Marketing demo lead delivery.
SCCC_MARKETING_LEAD_WEBHOOK_URL=https://hooks.example.com/sccc/demo-leads
SCCC_MARKETING_LEAD_WEBHOOK_SECRET=

# Billing.
SCCC_BILLING_PROVIDER=none
SCCC_STRIPE_SECRET_KEY=
SCCC_STRIPE_PRICE_STARTER=
SCCC_STRIPE_PRICE_PRO=
SCCC_STRIPE_PRICE_AGENCY=
SCCC_BILLING_SUCCESS_URL=https://app.example.com/dashboard?billing=success
SCCC_BILLING_CANCEL_URL=https://app.example.com/dashboard?billing=cancel
SCCC_BILLING_PORTAL_RETURN_URL=https://app.example.com/dashboard
STRIPE_WEBHOOK_SECRET=

# Google Search Console OAuth.
SCCC_GSC_CLIENT_ID=
SCCC_GSC_CLIENT_SECRET=
SCCC_GSC_REDIRECT_URI=https://app.example.com/api/integrations/gsc/callback
SCCC_GSC_STATE_SECRET=

# Assistant AI provider. Leave unset for deterministic-only recommendations.
SCCC_AI_PROVIDER=
SCCC_AI_API_KEY=
SCCC_AI_MODEL=

# Observability.
POSTHOG_KEY=
POSTHOG_HOST=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Worker health endpoint. Keep this private behind localhost/VPN/load-balancer checks.
SCCC_WORKER_HEALTH_PORT=8080
