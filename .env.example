NODE_ENV=development

# SaaS
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://sccc:sccc@localhost:5432/sccc?schema=public
REDIS_URL=redis://localhost:6379
AUTH_SECRET=replace-with-a-long-random-secret
SCCC_PLUGIN_SIGNING_SECRET=replace-with-plugin-signing-secret
SCCC_DATA_STORE=prisma

# Email delivery
SCCC_EMAIL_TRANSPORT=noop
SCCC_EMAIL_FROM="SEO Content Control Center <no-reply@localhost>"
SCCC_SMTP_HOST=localhost
SCCC_SMTP_PORT=1025
SCCC_SMTP_SECURE=false
SCCC_SMTP_USER=
SCCC_SMTP_PASSWORD=

# Marketing
NEXT_PUBLIC_MARKETING_URL=http://localhost:3001

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sccc-local
S3_ACCESS_KEY_ID=sccc
S3_SECRET_ACCESS_KEY=sccc-password

# Billing
SCCC_BILLING_PROVIDER=none
SCCC_STRIPE_SECRET_KEY=
SCCC_STRIPE_PRICE_STARTER=
SCCC_STRIPE_PRICE_PRO=
SCCC_STRIPE_PRICE_AGENCY=
SCCC_BILLING_SUCCESS_URL=
SCCC_BILLING_CANCEL_URL=
STRIPE_WEBHOOK_SECRET=

# Analytics placeholders for future iterations
POSTHOG_KEY=
SENTRY_DSN=
