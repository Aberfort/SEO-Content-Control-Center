NODE_ENV=development

# SaaS
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://sccc:sccc@localhost:5432/sccc?schema=public
# Disposable target for npm run verify:backup-restore.
SCCC_RESTORE_TEST_DATABASE_URL=
REDIS_URL=redis://localhost:6379
# Rate limit counters use Redis when REDIS_URL is set. Set to "memory" to force the process-local store.
SCCC_RATE_LIMIT_STORE=
AUTH_SECRET=replace-with-a-long-random-secret
SCCC_PLUGIN_SIGNING_SECRET=replace-with-plugin-signing-secret
# Used for recoverable encrypted secrets, including GSC refresh tokens, plugin apply tokens, and TOTP 2FA secrets.
SCCC_TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
SCCC_DATA_STORE=prisma

# Email delivery
SCCC_EMAIL_TRANSPORT=noop
SCCC_EMAIL_FROM="SEO Content Control Center <no-reply@localhost>"
SCCC_SMTP_HOST=localhost
SCCC_SMTP_PORT=1025
SCCC_SMTP_SECURE=false
SCCC_SMTP_USER=
SCCC_SMTP_PASSWORD=

# Marketing
NEXT_PUBLIC_MARKETING_URL=http://localhost:3001
# POST receives JSON demo-request events. In development, unset webhook delivery logs locally.
SCCC_MARKETING_LEAD_WEBHOOK_URL=
# Optional Bearer token sent to the demo lead webhook.
SCCC_MARKETING_LEAD_WEBHOOK_SECRET=

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sccc-local
S3_ACCESS_KEY_ID=sccc
S3_SECRET_ACCESS_KEY=sccc-password

# Billing
SCCC_BILLING_PROVIDER=none
SCCC_STRIPE_SECRET_KEY=
SCCC_STRIPE_PRICE_STARTER=
SCCC_STRIPE_PRICE_PRO=
SCCC_STRIPE_PRICE_AGENCY=
SCCC_BILLING_SUCCESS_URL=
SCCC_BILLING_CANCEL_URL=
SCCC_BILLING_PORTAL_RETURN_URL=
STRIPE_WEBHOOK_SECRET=

# Google Search Console OAuth
SCCC_GSC_CLIENT_ID=
SCCC_GSC_CLIENT_SECRET=
SCCC_GSC_REDIRECT_URI=
SCCC_GSC_STATE_SECRET=

# Observability (optional; error tracking and server analytics stay disabled while unset)
POSTHOG_KEY=
POSTHOG_HOST=
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# Worker health endpoint (optional; exposes GET /healthz with queue metrics when set)
SCCC_WORKER_HEALTH_PORT=
